# https://editorconfig.org — universal editor settings
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

[*.md]
trim_trailing_whitespace = false   # markdown uses trailing spaces for line breaks
max_line_length = off

[*.{yml,yaml}]
indent_size = 2

[Makefile]
indent_style = tab

[*.{sql}]
indent_size = 4
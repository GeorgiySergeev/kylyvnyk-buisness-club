{
  "name": "kclub-mvp",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": "20.x",
    "pnpm": ">=9.15.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "pnpm test:vitest",
    "test:vitest": "pnpm test:unit && pnpm test:integration && pnpm test:component",
    "test:unit": "vitest run --config vitest.config.ts --project unit --project contract",
    "test:integration": "vitest run --config vitest.config.ts --project integration",
    "test:component": "vitest run --config vitest.config.ts --project component",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.ts --project unit --project integration --project contract --project component",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:auth": "vitest run --config vitest.config.ts --project unit tests/unit/auth tests/unit/admin",
    "vocab:check": "node scripts/vocab-check.mjs",
    "env:check": "node scripts/env-check.mjs",
    "smoke:routes": "node scripts/smoke-routes.mjs",
    "verify": "pnpm lint && pnpm vocab:check && pnpm env:check && pnpm build && pnpm typecheck && pnpm test",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "echo 'Use db:migrate instead. db:push disabled.' && exit 1",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "5.4.0",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@sentry/nextjs": "10.56.0",
    "@stripe/react-stripe-js": "6.5.0",
    "@stripe/stripe-js": "9.7.0",
    "@supabase/ssr": "0.10.3",
    "@supabase/supabase-js": "2.106.1",
    "@upstash/ratelimit": "2.0.5",
    "@upstash/redis": "1.34.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "^0.36",
    "lucide-react": "1.16.0",
    "next": "15.5.18",
    "postgres": "^3.4.5",
    "qrcode.react": "^4",
    "radix-ui": "^1.4.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "7.76.0",
    "shadcn": "^4.8.1",
    "stripe": "17.7.0",
    "tailwind-merge": "3.6.0",
    "typescript": "^5",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@faker-js/faker": "9.8.0",
    "@playwright/test": "1.60.0",
    "@tailwindcss/postcss": "4.3.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.8",
    "cross-env": "10.1.0",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.28",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "jsdom": "29.1.1",
    "msw": "2.14.6",
    "prettier": "^3.5.3",
    "tailwindcss": "4.3.0",
    "tsx": "^4.19.4",
    "tw-animate-css": "1.4.0",
    "vitest": "4.1.8"
  }
}

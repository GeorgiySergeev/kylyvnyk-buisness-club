# ─────────────────────────────────────────────────────────────────
# KCLUB-MVP — .env.example
# ─────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in the values.
# See /docs/ENV.md for where each value comes from and who owns it.
# All variables listed here are REQUIRED unless marked OPTIONAL.
# ─────────────────────────────────────────────────────────────────


# ─── App ─────────────────────────────────────────────────────────
# Public base URL of the app. No trailing slash.
# dev:  http://localhost:3000
# prod: https://kclub.example.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment. Set by the platform in prod; only override locally.
# Values: development | test | production
NODE_ENV=development


# ─── Database (Supabase Postgres, see ADR-003) ───────────────────
# Pooled connection (PgBouncer transaction mode). Used by the app at runtime.
# IMPORTANT: in `src/db/client.ts` we pass `prepare: false` for this URL.
# Format: postgres://USER:PASS@HOST:6543/DB?pgbouncer=true&connection_limit=1
DATABASE_URL=postgres://postgres:REPLACE_ME@db.REPLACE_ME.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1

# Direct connection (session mode). Used by drizzle-kit migrations ONLY.
# Format: postgres://USER:PASS@HOST:5432/DB
DATABASE_URL_DIRECT=postgres://postgres:REPLACE_ME@db.REPLACE_ME.supabase.co:5432/postgres


# ─── Authentication (Clerk v6, see ADR-004) ──────────────────────
# Publishable key — safe to expose to the client.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Secret key — SERVER ONLY. Never expose.
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# Webhook signing secret for /api/clerk/webhook.
# Get from Clerk Dashboard → Webhooks → Endpoint → Signing Secret.
CLERK_WEBHOOK_SECRET=whsec_REPLACE_ME

# Where Clerk should redirect after sign-in / sign-up.
# Use absolute paths under /[locale]/.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/en/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/en/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/en/m/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/en/m/onboarding


# ─── Billing (Stripe v17, see ADR-005) ───────────────────────────
# Secret key — SERVER ONLY.
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Publishable key — safe for the client.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Webhook signing secret for /api/stripe/webhook.
# In dev: from `stripe listen` output.
# In prod: from Stripe Dashboard → Developers → Webhooks → your endpoint.
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Price IDs. Create products in Stripe Dashboard first.
# Format: price_XXXXXXXXXXXXXX
STRIPE_PRICE_VIP_ANNUAL=price_REPLACE_ME
STRIPE_PRICE_BUSINESS_ANNUAL=price_REPLACE_ME

# Customer Portal configuration ID (Stripe → Settings → Billing → Customer Portal).
# Used so all users land on the same portal flow.
STRIPE_PORTAL_CONFIGURATION_ID=bpc_REPLACE_ME


# ─── Rate limiting (Upstash, see ADR-008) ────────────────────────
UPSTASH_REDIS_REST_URL=https://REPLACE_ME.upstash.io
UPSTASH_REDIS_REST_TOKEN=REPLACE_ME


# ─── Bot defense (Cloudflare Turnstile, see ADR-008) ─────────────
# Site key — safe for the client.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAAREPLACE_ME

# Secret key — SERVER ONLY. Used for `siteverify`.
TURNSTILE_SECRET_KEY=0x4AAAAAAAREPLACE_ME


# ─── Observability (Sentry, see ADR-009) ─────────────────────────
# DSN — safe for the client (Sentry's design).
NEXT_PUBLIC_SENTRY_DSN=https://REPLACE_ME@oREPLACE_ME.ingest.sentry.io/REPLACE_ME

# Organization + project slugs, used only during source map upload in CI.
SENTRY_ORG=kclub
SENTRY_PROJECT=kclub-web

# Auth token for source map upload. CI ONLY. Do NOT put in local .env.
# SENTRY_AUTH_TOKEN=sntrys_REPLACE_ME


# ─── Analytics (Plausible, see ADR-009) ──────────────────────────
# Domain you registered in Plausible (without protocol).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=kclub.example.com


# ─── Email (transactional, OPTIONAL at MVP) ──────────────────────
# Resend is the default. Skip in dev; Clerk handles auth emails itself.
# RESEND_API_KEY=re_REPLACE_ME
# EMAIL_FROM="KCLUB <hello@kclub.example.com>"


# ─── Internal flags ──────────────────────────────────────────────
# Set to "1" to allow seed script execution. DATABASE_URL must still point to
# localhost, 127.0.0.1, or ::1, and CONFIRM_SEED must equal "I_CONFIRM".
ALLOW_SEED=

# Required exact confirmation token for destructive local seed operations.
CONFIRM_SEED=

# Set to "1" to disable the forbidden-vocab grep in local dev (CI ignores this).
# Useful only when editing /docs/GUARDRAILS.md itself. Default: empty.
DISABLE_VOCAB_GREP=
